<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" 
    xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd" 
    xmlns:content="http://purl.org/rss/1.0/modules/content/">
    <channel>
        <title>{{ podcast.title }}</title>
        <link>{{ request.url_root }}</link>
        <description><![CDATA[{{ podcast.description }}]]></description>
        <language>{{ podcast.language | default('es') }}</language>
        <itunes:author>{{ podcast.author }}</itunes:author>
        <itunes:owner>
            <itunes:name>{{ podcast.author }}</itunes:name>
            <itunes:email>{{ email }}</itunes:email>
        </itunes:owner>
        
        {% if podcast.cover_image %}
        <itunes:image href="{{ request.url_root }}static/media/{{ podcast.cover_image }}"/>
        {% endif %}
        
        {% if podcast.category %}
        <itunes:category text="{{ podcast.category }}"/>
        {% endif %}
        
        <itunes:explicit>no</itunes:explicit>

        {% for ep in podcast.episodes %}
        <item>
            <title>{{ ep.title }}</title>
            <link>{{ request.url_root }}</link>
            
            <guid isPermaLink="false">{{ request.url_root }}episodio/{{ ep.slug }}</guid>
            
            <description><![CDATA[{{ ep.description }}]]></description>
            
            <pubDate>{{ ep.pub_date | rfc2822 }}</pubDate>
            
            <enclosure 
                url="{{ request.url_root }}static/media/{{ ep.audio_file }}" 
                length="{{ ep.byte_size }}" 
                type="audio/mpeg" 
            />
            
            <itunes:duration>{{ ep.duration }}</itunes:duration>
            
            <itunes:explicit>{{ 'yes' if ep.explicit else 'no' }}</itunes:explicit>
        </item>
        {% endfor %}
    </channel>
</rss>
